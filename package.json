{
  "name": "studiodesk",
  "description": "StudioDESK — Professional audio collaboration DAW for recording engineers and artists",
  "author": "Shantel Bradford <shantelbridget93@gmail.com>",
  "private": true,
  "version": "0.2.5",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm run electron:serve\"",
    "electron:serve": "wait-on tcp:5173 && tsc -p tsconfig.electron.json && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "tsc -b && vite build && tsc -p tsconfig.electron.json",
    "electron:build": "node scripts/build-icon.mjs && npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview",
    "rebuild:native": "electron-rebuild -f -w naudiodon"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@supabase/supabase-js": "^2.108.1",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^1.17.0",
    "naudiodon": "^2.3.6",
    "nodemailer": "^9.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "sharp": "^0.35.1",
    "to-ico": "^1.1.5",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.studiodesk.app",
    "productName": "StudioDESK",
    "directories": {
      "output": "dist-desktop"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "icon": "build/icon.ico",
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "StudioDESK",
      "runAfterFinish": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/naudiodon/**/*"
    ],
    "nodeGypRebuild": false,
    "npmRebuild": false,
    "publish": [
      {
        "provider": "github",
        "owner": "shantileemedia-developer",
        "repo": "studiodesk"
      }
    ]
  }
}
